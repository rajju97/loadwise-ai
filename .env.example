# Frontend (safe to expose; use the current Supabase publishable key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Backend authentication and quota validation.
# These may use the same URL and publishable key; never use or expose the service-role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Optional optimizer tuning. All values are clamped to safe server-side limits.
OPTIMIZER_POPULATION=8
OPTIMIZER_GENERATIONS=6
OPTIMIZER_TIME_BUDGET_SECONDS=8

# Optional comma-separated cross-origin clients. Same-origin Vercel requests need no entry.
ALLOWED_ORIGINS=http://localhost:5173
