# Frontend (safe to expose; use the current Supabase publishable key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Optional optimizer tuning for the Python function
OPTIMIZER_POPULATION=18
OPTIMIZER_GENERATIONS=16

# Optional comma-separated cross-origin clients. Same-origin Vercel requests need no entry.
ALLOWED_ORIGINS=http://localhost:5173
